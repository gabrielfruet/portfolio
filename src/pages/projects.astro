---
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SectionHeader from "../components/SectionHeader.astro";

const projects = [
  {
    title: "CUDA Voxelization for PyTorch",
    description: "A fast voxelization implementation for PyTorch using CUDA.",
    tech: ["C++", "CUDA", "PyTorch"],
    link: "https://github.com/gabrielfruet/cuda-voxelization-torch",
  },
];

const contributions = [
  {
    title: "PyTorch Ignite",
    description: "Contributed to PyTorch Ignite, with focus on improving the metrics and logging API.",
    link: "https://github.com/pytorch/ignite",
  },
  {
    title: "Lightly",
    description: "Contributed to Lightly, implementing novel Self-supervised learning methods like SparK.",
    link: "https://github.com/lightly-ai/lightly",
  },
];
---

<BaseLayout title="Projects | Gabriel Fruet">
  <Header />

  <main>
    <PageHeader title="Projects" />

    <section class="mb-16">
      <ul class="space-y-0">
        {
          projects.map((project) => (
            <li class="py-4">
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group block"
              >
                <div class="flex items-baseline gap-3 mb-1">
                  <span class="text-[16px] text-[#ebdbb2] group-hover:underline">
                    {project.title}
                  </span>
                  <span class="text-[13px] text-[#928374]">
                    {project.tech.join(" · ")}
                  </span>
                </div>
                <p class="text-[14px] text-[#928374] leading-relaxed max-w-[540px]">
                  {project.description}
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section>
      <SectionHeader title="Open Source" />

      <ul class="space-y-0">
        {
          contributions.map((contribution) => (
            <li class="py-4">
              <a
                href={contribution.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group block"
              >
                <div class="mb-1">
                  <span class="text-[16px] text-[#ebdbb2] group-hover:underline">
                    {contribution.title}
                  </span>
                </div>
                <p class="text-[14px] text-[#928374] leading-relaxed max-w-[540px]">
                  {contribution.description}
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>
