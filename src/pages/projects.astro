---
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "CUDA Voxelization for PyTorch",
    description: "A fast voxelization implementation for PyTorch using CUDA.",
    tech: ["C++", "CUDA", "PyTorch"],
    link: "https://github.com/gabrielfruet/cuda-voxelization-torch",
  },
];

const contributions = [
  {
    title: "PyTorch Ignite",
    description: "Contributed to PyTorch Ignite, with focus on improving the metrics and logging API.",
    link: "https://github.com/pytorch/ignite",
  },
  {
    title: "Lightly",
    description: "Contributed to Lightly, implementing novel Self-supervised learning methods like SparK.",
    link: "https://github.com/lightly-ai/lightly",
  },
];
---

<BaseLayout title="Projects | Gabriel Fruet">
  <Header />

  <main>
    <h1 class="text-3xl md:text-4xl mb-16 text-foreground">
      Projects
    </h1>

    <section class="mb-16">
      <p class="text-muted text-lg leading-relaxed mb-8">
        A selection of projects I've built and contributed to.
      </p>

      <div class="space-y-12">
        {
          projects.map((project) => (
            <article>
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group block"
              >
                <h2 class="text-xl text-foreground group-hover:text-accent transition-colors duration-200 inline">
                  {project.title}
                </h2>
              </a>
              <p class="text-muted mt-2 leading-relaxed max-w-xl">
                {project.description}
              </p>
              <p class="text-muted text-sm mt-3">
                {project.tech.join(" · ")}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section>
      <h2 class="text-xl mb-8 text-muted uppercase tracking-widest font-normal">
        Open Source Contributions
      </h2>

      <div class="space-y-10">
        {
          contributions.map((contribution) => (
            <article>
              <a
                href={contribution.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group block"
              >
                <h3 class="text-lg text-foreground group-hover:text-accent transition-colors duration-200 inline">
                  {contribution.title}
                </h3>
              </a>
              <p class="text-muted mt-2 leading-relaxed max-w-xl">
                {contribution.description}
              </p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
