---
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SectionHeader from "../components/SectionHeader.astro";

const projects = [
  {
    title: "CUDA Voxelization for PyTorch",
    description: "A fast voxelization implementation for PyTorch using CUDA.",
    tech: ["C++", "CUDA", "PyTorch"],
    link: "https://github.com/gabrielfruet/cuda-voxelization-torch",
  },
];

const contributions = [
  {
    title: "PyTorch Ignite",
    description: "Contributed to PyTorch Ignite, with focus on improving the metrics and logging API.",
    link: "https://github.com/pytorch/ignite",
  },
  {
    title: "Lightly",
    description: "Contributed to Lightly, implementing novel Self-supervised learning methods like SparK.",
    link: "https://github.com/lightly-ai/lightly",
  },
];
---

<BaseLayout title="Projects | Gabriel Fruet">
  <Header />

  <main>
    <PageHeader title="Projects" />

    <section class="mb-16">
      <ul class="space-y-0">
        {
          projects.map((project) => (
            <li class="py-2">
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-baseline gap-3 hover:opacity-70 transition-opacity duration-150"
              >
                <span class="text-[15px] text-[#e8e4dc] group-hover:underline">
                  {project.title}
                </span>
                <span class="text-[13px] text-[#6e6a67]">
                  {project.tech.join(" · ")}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section>
      <SectionHeader title="Open Source" />

      <ul class="space-y-0">
        {
          contributions.map((contribution) => (
            <li class="py-2">
              <a
                href={contribution.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-baseline gap-3 hover:opacity-70 transition-opacity duration-150"
              >
                <span class="text-[15px] text-[#e8e4dc] group-hover:underline">
                  {contribution.title}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>
