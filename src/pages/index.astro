---
import { getCollection } from "astro:content";
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Gabriel Fruet | Computer Vision Engineer">
  <Header />

  <main>
    <h1 class="text-3xl md:text-4xl mb-10 text-foreground">
      Hi, I'm Gabriel.
    </h1>

    <div class="prose prose-invert prose-lg mb-16 text-muted">
      <p class="leading-relaxed">
        I am a Computer Vision Engineer working on LiDAR perception and
        autonomous systems. I write about machine learning, computer vision,
        and the intersection of research and engineering.
      </p>
      <p class="leading-relaxed mt-6">
        I contribute to <a href="https://github.com/pytorch/ignite" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">PyTorch Ignite</a> and <a href="https://github.com/lightly-ai/lightly" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Lightly</a>.
      </p>
    </div>

    <section>
      <h2 class="text-base font-medium text-foreground mb-8">Latest Posts</h2>
      <ul class="space-y-0">
        {
          posts.map((post) => (
            <li class="py-2">
              <a
                href={`${import.meta.env.BASE_URL}/blog/${post.slug}`}
                class="group inline-flex items-baseline gap-3 hover:opacity-70 transition-opacity duration-150"
              >
                <span class="text-[13px] text-[#6e6a67] tabular-nums shrink-0">
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                  })}
                </span>
                <span class="text-[15px] text-foreground group-hover:underline">
                  {post.data.title}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href={`${import.meta.env.BASE_URL}/blog`}
        class="inline-block mt-6 text-sm text-[#6e6a67] hover:text-foreground transition-colors duration-150"
      >
        All posts →
      </a>
    </section>
  </main>
</BaseLayout>
