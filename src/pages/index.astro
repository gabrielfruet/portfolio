---
import { getCollection } from "astro:content";
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Gabriel Fruet | Computer Vision Engineer">
  <Header />

  <main>
    <h1 class="text-[2rem] md:text-[2.25rem] mb-10 text-[#e8e4dc] tracking-tight">
      Hi, I'm Gabriel.
    </h1>

    <div class="mb-16 text-[#8a857c]">
      <p class="text-[16px] leading-relaxed mb-4">
        I am a Computer Vision Engineer working on LiDAR perception and
        autonomous systems. I write about machine learning, computer vision,
        and the intersection of research and engineering.
      </p>
      <p class="text-[16px] leading-relaxed">
        I contribute to <a href="https://github.com/pytorch/ignite" target="_blank" rel="noopener noreferrer" class="text-[#c4a77d] hover:underline">PyTorch Ignite</a> and <a href="https://github.com/lightly-ai/lightly" target="_blank" rel="noopener noreferrer" class="text-[#c4a77d] hover:underline">Lightly</a>.
      </p>
    </div>

    <section>
      <h2 class="text-[15px] font-medium text-[#e8e4dc] tracking-tight mb-8">Latest Posts</h2>
      <ul class="space-y-0">
        {
          posts.map((post) => (
            <li class="py-3">
              <a
                href={`${import.meta.env.BASE_URL}/blog/${post.slug}`}
                class="group block"
              >
                <div class="flex items-baseline gap-3 mb-1">
                  <span class="text-[13px] text-[#6e6a67] tabular-nums shrink-0">
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                    })}
                  </span>
                  <span class="text-[16px] text-[#e8e4dc] group-hover:underline">
                    {post.data.title}
                  </span>
                </div>
                <p class="text-[14px] text-[#6e6a67] leading-relaxed max-w-[540px] pl-[84px]">
                  {post.data.description}
                </p>
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href={`${import.meta.env.BASE_URL}/blog`}
        class="inline-block mt-6 text-[14px] text-[#6e6a67] hover:text-[#e8e4dc] transition-colors duration-150"
      >
        All posts →
      </a>
    </section>
  </main>
</BaseLayout>
