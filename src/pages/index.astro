---
import { getCollection } from "astro:content";
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Gabriel Fruet | Computer Vision Engineer">
  <Header />

  <main>
    <h1 class="text-[2rem] md:text-[2.25rem] mb-10 text-[#e8e4dc] tracking-tight">
      Hi, I'm Gabriel.
    </h1>

    <div class="mb-16 text-[#8a857c]">
      <p class="text-[16px] leading-relaxed mb-4">
        I am a Computer Vision Engineer working on LiDAR perception and
        autonomous systems. I write about machine learning, computer vision,
        and the intersection of research and engineering.
      </p>
      <p class="text-[16px] leading-relaxed">
      I contribute to <a href="https://github.com/pytorch/ignite" target="_blank" rel="noopener noreferrer" class="text-[#c4a77d] hover:underline">PyTorch Ignite</a>, <a href="https://github.com/lightly-ai/lightly-train" target="_blank" rel="noopener noreferrer" class="text-[#c4a77d] hover:underline">LightlyTrain</a> and <a href="https://github.com/lightly-ai/lightly" target="_blank" rel="noopener noreferrer" class="text-[#c4a77d] hover:underline">LightlySSL</a>.
      </p>
    </div>

    <div class="mt-20 pt-12 border-t border-[#2a2722]">
      <h2 class="text-[12px] uppercase tracking-wider text-[#6e6a67] mb-4">Writing</h2>
      <ul class="space-y-0">
        {
          posts.map((post) => (
            <li class="py-1">
              <a
                href={`${import.meta.env.BASE_URL}/blog/${post.slug}`}
                class="group inline-flex items-baseline gap-3 hover:opacity-70 transition-opacity duration-150"
              >
                <span class="text-[13px] text-[#6e6a67] tabular-nums shrink-0">
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                  })}
                </span>
                <span class="text-[15px] text-[#e8e4dc] group-hover:underline">
                  {post.data.title}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href={`${import.meta.env.BASE_URL}/blog`}
        class="mt-6 inline-block text-[14px] text-[#e8e4dc] hover:underline"
      >
        All posts →
      </a>
    </div>
  </main>
</BaseLayout>
