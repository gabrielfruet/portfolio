---
import { getCollection } from "astro:content";
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog | Gabriel Fruet">
  <Header />

  <main>
    <h1 class="text-lg font-semibold mb-8 text-[#8A8A8A] uppercase tracking-wider">
      Blog
    </h1>

    <ul class="space-y-0">
      {
        posts.map((post) => (
          <li class="py-5 border-b border-[#403E3C] hover:bg-[#2A2927] rounded-lg px-3 -mx-3 transition-colors duration-200">
            <a
              href={`${import.meta.env.BASE_URL}/blog/${post.slug}`}
              class="block"
            >
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-2">
                <h2 class="text-xl font-medium text-[#CECDC3] group-hover:text-white transition-colors">
                  {post.data.title}
                </h2>
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-sm text-[#575653] whitespace-nowrap mt-1 sm:mt-0"
                >
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </div>

              <p class="text-[#575653] text-base leading-relaxed max-w-2xl">
                {post.data.description}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
