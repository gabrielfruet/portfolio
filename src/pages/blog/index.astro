---
import { getCollection } from "astro:content";
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog | Gabriel Fruet">
  <Header />

  <main>
    <PageHeader title="Blog" />

    <ul class="space-y-0">
      {
        posts.map((post) => (
          <li class="py-2">
            <a
              href={`${import.meta.env.BASE_URL}/blog/${post.slug}`}
              class="group inline-flex items-baseline gap-3 hover:opacity-70 transition-opacity duration-150"
            >
              <span class="text-[13px] text-[#6e6a67] tabular-nums shrink-0">
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                })}
              </span>
              <span class="text-[15px] text-[#e8e4dc] group-hover:underline">
                {post.data.title}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
