---
interface Props {
    title: string;
    authors: string[];
    venue: string;
    year: string;
    link?: string;
    abstract?: string;
}

const { title, authors, venue, year, link, abstract } = Astro.props;
---

<li class="py-3">
    <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline"
    >
        <span class="text-[15px] text-[#e8e4dc] group-hover:underline">
            {title}
        </span>
    </a>
    <div class="text-[13px] text-[#6e6a67] mt-1">
        {authors.join(", ")} · {venue}, {year}
    </div>
</li>
