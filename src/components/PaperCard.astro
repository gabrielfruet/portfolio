---
interface Props {
    title: string;
    authors: string[];
    venue: string;
    year: string;
    link?: string;
    abstract?: string;
}

const { title, authors, venue, year, link, abstract } = Astro.props;
---

<li class="py-4">
    <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="group block"
    >
        <div class="text-[16px] text-[#e8e4dc] group-hover:underline mb-1">
            {title}
        </div>
        <div class="text-[13px] text-[#6e6a67]">
            {authors.join(", ")}
            <span class="mx-1">·</span>
            <span class="italic">{venue}</span>
            <span class="mx-1">,</span>
            <span>{year}</span>
        </div>
        {abstract && (
            <p class="text-[14px] text-[#6e6a67] mt-2 leading-relaxed max-w-[600px] italic opacity-80">
                {abstract}
            </p>
        )}
    </a>
</li>
