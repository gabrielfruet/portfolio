---
const contributions = [
    {
        name: "PyTorch Ignite",
        url: "https://github.com/pytorch/ignite",
    },
    {
        name: "Lightly",
        url: "https://github.com/lightly-ai/lightly",
    },
];
---

<p class="text-base text-[#575653] mb-12">
    Contributing to:{" "}
    {
        contributions.map((item, index) => (
            <>
                <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#CECDC3] hover:underline"
                >
                    {item.name}
                </a>
                {index < contributions.length - 1 && ", "}
            </>
        ))
    }
</p>
