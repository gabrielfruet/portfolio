---
const contributions = [
    {
        name: "PyTorch Ignite",
        url: "https://github.com/pytorch/ignite",
    },
    {
        name: "Lightly",
        url: "https://github.com/lightly-ai/lightly",
    },
];
---

<div class="mb-8">
    <p class="text-sm text-neutral-400">
        Contributing to:{" "}
        {
            contributions.map((item, index) => (
                <>
                    <a
                        href={item.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-neutral-300 hover:underline"
                    >
                        {item.name}
                    </a>
                    {index < contributions.length - 1 && ", "}
                </>
            ))
        }
    </p>
</div>
